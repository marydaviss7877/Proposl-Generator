# Copy to .env.local for local dev. In production these are set as Railway
# environment variables — never commit real values.

# ─── Basic Auth (gates the entire app — see middleware.ts) ─────────────────
# If unset, the app runs open. MUST be set on the Railway production service.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ─── Persistent volume paths (Railway) ──────────────────────────────────────
# In production these MUST point at the mounted volume (e.g. /data/...) or
# edits/tokens are lost on every redeploy. Local dev falls back to ./data and
# ./.cache if unset.
PORTFOLIO_PATH=
ENGINE_PATH=
MODEL_CACHE_PATH=

# ─── Upwork OAuth 2.0 (see UPWORK_API_ONBOARDING_GUIDE.md) ──────────────────
# From the Upwork Developer Portal — server-side only, never sent to the client.
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=
# Must exactly match the Callback URL registered with Upwork.
UPWORK_REDIRECT_URI=https://bidflow.up.railway.app/api/auth/upwork/callback
# Where the OAuth token file is persisted. MUST point at the Railway volume in
# production (e.g. /data/upwork-tokens.json) or the connection is lost on
# every redeploy, forcing re-authorization. Local dev defaults to
# .cache/upwork-tokens.json if unset.
UPWORK_TOKEN_PATH=
